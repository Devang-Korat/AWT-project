const mongoose = require("mongoose");

const expenseSchema = new mongoose.Schema({
  addedBy: {
    type: mongoose.Schema.Types.ObjectId,
    ref: "User",
    required: true
  },

  title: {
    type: String,
    required: true
  },

  amount: {
    type: Number,
    required: true
  },

  description: {
    type: String,
    required: true
  },

  expenseDate: {
    type: Date,
    required: true
  }

}, { timestamps: true });

module.exports = mongoose.model("Expense", expenseSchema, "expense");